<?xml version="1.0"?>
<sdf version="1.9">
  <model name="yahboomcar_X3">
    <link name="base_footprint">
      <inertial>
        <pose>0.00687 0.000117 0.0824 0 0 0</pose>
        <mass>0.5346</mass>
        <inertia>
          <ixx>0.00289</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00554</iyy>
          <iyz>0</iyz>
          <izz>0.00501</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.0815 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/base_link_X3.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.0815 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/base_link_X3.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0 0.875 0 1</diffuse>
          <ambient>0 0.875 0 1</ambient>
        </material>
      </visual>
    </link>

    <!-- laser_link：与 URDF 中 base_footprint→base_link→laser 等效位姿 -->
    <!-- 位姿全在 joint 上，link 用默认系，避免 relative_to=joint 在 Gazebo 里触发 PoseRelativeToGraph 环 -->
    <joint name="laser_fixed" type="fixed">
      <parent>base_footprint</parent>
      <child>laser_link</child>
      <pose>0.0435 0 0.1915 0 0 0</pose>
    </joint>
    <link name="laser_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia>
          <ixx>1e-6</ixx>
          <iyy>1e-6</iyy>
          <izz>1e-6</izz>
        </inertia>
      </inertial>
      <visual name="laser_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/laser_link.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.875 0.875 0.875 1</diffuse>
          <ambient>0.875 0.875 0.875 1</ambient>
        </material>
      </visual>
      <!-- 2D 激光：尽量走软件/CPU 路径，减少对 VM 图形栈依赖 -->
      <sensor name="lidar" type="lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>scan</topic>
        <gz_frame_id>laser_link</gz_frame_id>
        <update_rate>20</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>1</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>0</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
        <always_on>1</always_on>
        <!-- VM 无 GPU 时 visualize 可能拖垮渲染管线；CPU lidar 射线不依赖可视化 -->
        <visualize>false</visualize>
      </sensor>
    </link>
    <joint name="back_left_joint" type="revolute">
      <parent>base_footprint</parent>
      <child>back_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>1</velocity>
        </limit>
      </axis>
      <pose>-0.08 0.084492 0.042 1.5703 0 0</pose>
    </joint>
    <link name="back_left_wheel">
      <inertial>
        <mass>0.0515</mass>
        <inertia>
          <ixx>1.46e-5</ixx>
          <iyy>1.46e-5</iyy>
          <izz>2.43e-5</izz>
        </inertia>
      </inertial>
      <collision name="blw_collision">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/back_left_wheel_X3.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="blw_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/back_left_wheel_X3.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.875 0.875 0.875 1</diffuse>
          <ambient>0.875 0.875 0.875 1</ambient>
        </material>
      </visual>
    </link>
    <joint name="back_right_joint" type="revolute">
      <parent>base_footprint</parent>
      <child>back_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>1</velocity>
        </limit>
      </axis>
      <pose>-0.08 -0.0845 0.042 -1.57 0 3.14159</pose>
    </joint>
    <link name="back_right_wheel">
      <inertial>
        <mass>0.0515</mass>
        <inertia>
          <ixx>1.46e-5</ixx>
          <iyy>1.46e-5</iyy>
          <izz>2.43e-5</izz>
        </inertia>
      </inertial>
      <collision name="brw_collision">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/back_right_wheel_X3.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="brw_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/back_right_wheel_X3.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.875 0.875 0.875 1</diffuse>
          <ambient>0.875 0.875 0.875 1</ambient>
        </material>
      </visual>
    </link>
    <joint name="front_left_joint" type="revolute">
      <parent>base_footprint</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>1</velocity>
        </limit>
      </axis>
      <pose>0.08 0.084492 0.0426 1.5703 0 0</pose>
    </joint>
    <link name="front_left_wheel">
      <inertial>
        <mass>0.0515</mass>
        <inertia>
          <ixx>1.46e-5</ixx>
          <iyy>1.46e-5</iyy>
          <izz>2.43e-5</izz>
        </inertia>
      </inertial>
      <collision name="flw_collision">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/front_left_wheel_X3.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="flw_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/front_left_wheel_X3.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.875 0.875 0.875 1</diffuse>
          <ambient>0.875 0.875 0.875 1</ambient>
        </material>
      </visual>
    </link>
    <joint name="front_right_joint" type="revolute">
      <parent>base_footprint</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>1</velocity>
        </limit>
      </axis>
      <pose>0.08 -0.0845 0.0426 -1.5703 0 3.14159</pose>
    </joint>
    <link name="front_right_wheel">
      <inertial>
        <mass>0.0515</mass>
        <inertia>
          <ixx>1.46e-5</ixx>
          <iyy>1.46e-5</iyy>
          <izz>2.43e-5</izz>
        </inertia>
      </inertial>
      <collision name="frw_collision">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/front_right_wheel_X3.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="frw_visual">
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://yahboomcar_description/meshes/front_right_wheel_X3.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.875 0.875 0.875 1</diffuse>
          <ambient>0.875 0.875 0.875 1</ambient>
        </material>
      </visual>
    </link>

    <!-- Diff drive: use back_left + back_right for differential approximation -->
    <plugin
      filename="ignition-gazebo6-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>back_left_joint</left_joint>
      <right_joint>back_right_joint</right_joint>
      <wheel_separation>0.169</wheel_separation>
      <wheel_radius>0.038</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <!-- 显式指定：否则 gz 用「model/CanonicalLink」，CanonicalLink 若非 base_footprint 会与
           static TF(base_footprint→laser_link) 冲突，AMCL 无法求 laser_link→odom，永不发 map→odom -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </model>
</sdf>
